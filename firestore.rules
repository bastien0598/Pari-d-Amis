rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }
    
    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['username', 'createdAt']) &&
             data.username is string && data.username.size() > 0 && data.username.size() <= 50 &&
             data.createdAt is timestamp;
    }

    function isValidGroup(data) {
      return hasRequiredFields(['name', 'adminId', 'memberIds', 'status', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.adminId is string &&
             data.memberIds is list && data.memberIds.size() > 0 && data.memberIds.size() <= 100 &&
             (!('globalStake' in data) || (data.globalStake is string && data.globalStake.size() <= 200)) &&
             (!('emoji' in data) || (data.emoji is string && data.emoji.size() <= 10)) &&
             data.status in ['active', 'closed'] &&
             data.createdAt is timestamp;
    }

    function isValidGroupMember(data, userId) {
      return hasRequiredFields(['userId', 'points', 'joinedAt']) &&
             data.userId == userId &&
             data.points is number &&
             data.joinedAt is timestamp;
    }

    function isValidBet(data) {
      return hasRequiredFields(['creatorId', 'question', 'type', 'options', 'deadline', 'status', 'createdAt']) &&
             data.creatorId is string &&
             data.question is string && data.question.size() > 0 && data.question.size() <= 300 &&
             (!('emoji' in data) || (data.emoji is string && data.emoji.size() <= 10)) &&
             (!('allowCustomAnswers' in data) || data.allowCustomAnswers is bool) &&
             data.type in ['binary', 'multiple'] &&
             data.options is list && data.options.size() >= 2 && data.options.size() <= 20 &&
             data.deadline is timestamp &&
             data.status in ['open', 'closed', 'resolved'] &&
             (!('result' in data) || data.result is string) &&
             (!('resolvedAt' in data) || data.resolvedAt is timestamp) &&
             data.createdAt is timestamp;
    }

    function isValidVote(data, userId) {
      return hasRequiredFields(['userId', 'option', 'createdAt']) &&
             data.userId == userId &&
             data.option is string && data.option.size() > 0 && data.option.size() <= 100 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if true;
    }

    match /groups/{groupId} {
      allow read: if true;
      allow create: if isValidGroup(request.resource.data);
      allow update: if isValidGroup(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if true;
    }

    match /groups/{groupId}/members/{userId} {
      allow read: if true;
      allow create: if isValidGroupMember(request.resource.data, userId) &&
                    request.resource.data.points == 0;
      allow update: if isValidGroupMember(request.resource.data, userId) &&
                    request.resource.data.joinedAt == resource.data.joinedAt;
    }

    match /groups/{groupId}/bets/{betId} {
      allow read: if true;
      allow create: if isValidBet(request.resource.data);
      allow update: if isValidBet(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    request.resource.data.creatorId == resource.data.creatorId;
    }

    match /groups/{groupId}/bets/{betId}/votes/{userId} {
      allow read: if true;
      allow create: if isValidVote(request.resource.data, userId) &&
                    get(/databases/$(database)/documents/groups/$(groupId)/bets/$(betId)).data.status == 'open';
      allow update: if false;
    }
  }
}
